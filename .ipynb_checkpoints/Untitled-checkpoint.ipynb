    "def calc_dist_orig(G, orig_coords, dest):\n",
    "    orig_lon, orig_lat = orig_coords[0]\n",
    "    dest_x = G.nodes[dest][\"x\"]\n",
    "    dest_y = G.nodes[dest][\"y\"]\n",
    "    return round(ox.distance.great_circle(orig_lat, orig_lon, dest_y, dest_x))\n",
    "\n",
    "def get_rand_path(G, orig_coords, curr_path, node, max_length, length=0, visited=None):\n",
    "    if(length >= max_length):\n",
    "        return [node]\n",
    "\n",
    "    if visited is None:\n",
    "        visited = set()\n",
    "    visited.add(node)\n",
    "\n",
    "    neighbors = list(set(G.adj[node]) - visited)\n",
    "    if(len(neighbors) == 0):\n",
    "        return [node]\n",
    "\n",
    "    filtered_neighbors = []\n",
    "    for neighbor in neighbors:\n",
    "        if(calc_dist_orig(G,orig_coords, neighbor) + 100 >= calc_dist_orig(G,orig_coords, node)):\n",
    "            filtered_neighbors.append(neighbor)\n",
    "\n",
    "    if(len(filtered_neighbors) == 0):\n",
    "        return [node]\n",
    "\n",
    "    while(len(filtered_neighbors) > 0):\n",
    "        rand_idx = np.random.randint(0,len(filtered_neighbors))\n",
    "        neighbor = filtered_neighbors[rand_idx]\n",
    "        subpath = get_rand_path(G, orig_coords, curr_path, neighbor, max_length, \n",
    "                                 length + sum(ox.routing.route_to_gdf(G, [node, neighbor])[\"length\"]), visited)\n",
    "        \n",
    "        if paths_cross(G, [node] + subpath + curr_path, [neighbor, node] + subpath + curr_path):\n",
    "            filtered_neighbors.pop(rand_idx)\n",
    "            continue\n",
    "            \n",
    "        subpath_length = sum(ox.routing.route_to_gdf(G, [node] + subpath)[\"length\"])\n",
    "        if subpath_length + length >= max_length:\n",
    "            return [node] + subpath\n",
    "        else:\n",
    "            filtered_neighbors.pop(rand_idx)\n",
    "        \n",
    "    return [node]"
   ]
  },
