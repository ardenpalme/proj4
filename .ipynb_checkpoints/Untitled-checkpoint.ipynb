    "def get_accomodations(date, lat, lon):\n",
    "    full_loc = nearest_place(17.997, -76.793)\n",
    "    print(f\"({lat:.4f}, {lon:.4f}) {full_loc}\")\n",
    "\n",
    "    checkin= date\n",
    "    checkout= datetime.now() + timedelta(days=1)\n",
    "    \n",
    "    camp_results = serpapi_client.search({\n",
    "      \"engine\": \"google_maps\",\n",
    "      \"ll\": f\"@{lat},{lon},12z\",\n",
    "      \"q\": \"Campsites\"\n",
    "    })\n",
    "\n",
    "    hotel_results = serpapi_client.search({\n",
    "      \"engine\": \"google_hotels\",\n",
    "      \"q\": f\"hotel in {full_loc}\",\n",
    "      \"check_in_date\": f\"{checkin.strftime(\"%Y-%m-%d\")}\",\n",
    "      \"check_out_date\": f\"{checkout.strftime(\"%Y-%m-%d\")}\"\n",
    "    })\n",
    "\n",
    "    data = dict()\n",
    "    rate=[]\n",
    "    name=[]\n",
    "    geom=[]\n",
    "    \n",
    "    for res in camp_results[\"local_results\"]:\n",
    "        coords = res['gps_coordinates']\n",
    "        geom.append(Point(coords['longitude'], coords['latitude']))\n",
    "        rate.append(0)\n",
    "        name.append(res['title'])\n",
    "\n",
    "    for p in hotel_results[\"properties\"]:\n",
    "        coords = p['gps_coordinates']\n",
    "        geom.append(Point(coords['longitude'], coords['latitude']))\n",
    "        rate.append(p['rate_per_night']['extracted_lowest'])\n",
    "        name.append(p['name'])\n",
    "\n",
    "    return gpd.GeoDataFrame({'rate':rate, 'name':name}, geometry=geom)"
   ]
  },
